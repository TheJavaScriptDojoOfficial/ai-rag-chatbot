# Copy to .env and adjust as needed

APP_NAME=Company RAG API
APP_ENV=development
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=120

# Document ingestion (Phase 3)
DOCS_BASE_PATH=./docs
INGEST_MAX_FILE_SIZE_MB=10
CHUNK_SIZE_CHARS=1500
CHUNK_OVERLAP_CHARS=200
ALLOWED_DOC_EXTENSIONS=.pdf,.md,.txt

# Vector DB and embeddings (Phase 4)
VECTOR_DB_PROVIDER=chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=company_knowledge_base
OLLAMA_EMBED_MODEL=nomic-embed-text
VECTOR_SEARCH_TOP_K=5

# RAG orchestration (Phase 5)
# For long PDFs (e.g. 30+ pages), increase RAG_TOP_K (e.g. 12) and RAG_MAX_CONTEXT_CHARS so specific sections are retrieved
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=6000
RAG_MIN_SCORE=0.15
RAG_TEMPERATURE=0.2
RAG_SYSTEM_PROMPT_NAME=default_company_assistant

# Session and feedback storage (Phase 8)
APP_DATA_DIRECTORY=./data/app
SQLITE_DB_PATH=./data/app/chatbot.sqlite3
MAX_SESSION_MESSAGES_FOR_CONTEXT=8
SESSION_TITLE_MAX_CHARS=80
